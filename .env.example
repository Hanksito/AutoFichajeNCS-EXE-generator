# ============================================================
# Configuración de credenciales NCS Clock
# Copia este archivo como .env y rellena tus datos
# ============================================================

# Credenciales de login (solo si NO usas el perfil de Chrome)
NCS_USUARIO=tu_usuario_aqui
NCS_PASSWORD=tu_contraseña_aqui

# Ruta al perfil de Chrome (opcional, se autodetecta)
# CHROME_USER_DATA_DIR=C:\Users\TU_USUARIO\AppData\Local\Google\Chrome\User Data
# CHROME_PROFILE=Default

# Ruta al ejecutable de Chrome (opcional, se autodetecta)
# CHROME_BINARY=C:\Program Files\Google\Chrome\Application\chrome.exe
